<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>SportsStore</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <style>
            .cart-overlay { position: fixed; inset: 0; background: rgba(0,0,0,0.4); opacity: 0; pointer-events: none; transition: opacity .25s; z-index: 1040; }
            .cart-overlay.show { opacity: 1; pointer-events: all; }
            .cart-drawer { position: fixed; top: 0; right: 0; width: 380px; max-width: 95vw; height: 100%; background: #fff; border-left: 1px solid #dee2e6; transform: translateX(100%); transition: transform .3s cubic-bezier(.4,0,.2,1); z-index: 1050; display: flex; flex-direction: column; }
            .cart-drawer.open { transform: translateX(0); }
            .cart-drawer-header { padding: 1.25rem; border-bottom: 1px solid #dee2e6; display: flex; justify-content: space-between; align-items: center; }
            .cart-drawer-items { flex: 1; overflow-y: auto; padding: 1rem 1.25rem; }
            .cart-drawer-footer { padding: 1.25rem; border-top: 1px solid #dee2e6; }
            .cart-item-row { display: flex; gap: 10px; align-items: center; padding: .75rem 0; border-bottom: 1px solid #f0f0f0; }
            .cart-item-thumb { width: 48px; height: 48px; border: 1px solid #dee2e6; border-radius: 8px; background: #f8f9fa; display: flex; align-items: center; justify-content: center; flex-shrink: 0; color: #aaa; font-size: 20px; }
            .cart-item-info { flex: 1; }
            .cart-item-info .name { font-size: 14px; font-weight: 500; }
            .cart-item-info .cat { font-size: 12px; color: #6c757d; }
            .cart-item-right { text-align: right; }
            .cart-item-right .price { font-size: 14px; font-weight: 500; }
            .qty-ctrl { display: flex; align-items: center; gap: 6px; justify-content: flex-end; margin-top: 4px; }
            .qty-ctrl button { width: 24px; height: 24px; border: 1px solid #dee2e6; border-radius: 4px; background: transparent; cursor: pointer; font-size: 14px; line-height: 1; }
            .qty-ctrl button:hover { background: #f0f0f0; }
            .qty-ctrl span { font-size: 13px; font-weight: 500; min-width: 16px; text-align: center; }
            .cart-remove { font-size: 11px; color: #aaa; cursor: pointer; text-decoration: underline; }
            .cart-remove:hover { color: #dc3545; }
            .cart-badge { display: inline-block; background: #0d6efd; color: #fff; font-size: 11px; border-radius: 99px; padding: 1px 7px; margin-left: 6px; vertical-align: middle; }
            .summary-line { display: flex; justify-content: space-between; font-size: 13px; color: #6c757d; padding: 3px 0; }
            .summary-line .val { color: #212529; }
            .summary-total { display: flex; justify-content: space-between; font-size: 15px; font-weight: 600; padding: 10px 0 12px; }
            .btn-checkout { width: 100%; padding: 11px; background: #212529; color: #fff; border: none; border-radius: 8px; font-size: 14px; font-weight: 500; cursor: pointer; }
            .btn-checkout:hover { background: #343a40; }
            .cart-continue { text-align: center; font-size: 12px; color: #6c757d; margin-top: 8px; cursor: pointer; }
            .cart-continue:hover { color: #212529; }
    </style>
</head>
<body>
    <div class="navbar navbar-dark bg-dark mb-4">
        <div class="container">
            <a class="navbar-brand" asp-controller="Product" asp-action="List">SPORTS STORE</a>
            <button class="btn btn-outline-light btn-sm" onclick="openCart()">
                🛒 Cart <span class="cart-badge" id="nav-cart-count">0</span>
            </button>
        </div>
    </div>

    <div class="container">
        @RenderBody()
    </div>

    <!-- Cart Overlay -->
    <div class="cart-overlay" id="cartOverlay" onclick="closeCart()"></div>

    <!-- Cart Drawer -->
    <div class="cart-drawer" id="cartDrawer">
        <div class="cart-drawer-header">
            <strong>Shopping cart <span class="cart-badge" id="drawer-count">0</span></strong>
            <button onclick="closeCart()" style="background:none;border:none;font-size:20px;cursor:pointer;color:#6c757d;">✕</button>
        </div>
        <div class="cart-drawer-items" id="drawerItems">
            <p class="text-muted text-center mt-3" id="emptyMsg">Your cart is empty</p>
        </div>
        <div class="cart-drawer-footer" id="drawerFooter" style="display:none">
            <div class="summary-line"><span>Subtotal</span><span class="val" id="d-subtotal">₱0.00</span></div>
            <div class="summary-line"><span>Shipping</span><span style="color:#198754;font-weight:500">Free</span></div>
            <div class="summary-line"><span>Tax</span><span class="val">₱0.00</span></div>
            <div class="summary-total"><span>Total</span><span id="d-total">₱0.00</span></div>
           <button class="btn-checkout" onclick="window.location.href='/Cart/Checkout'">Proceed to checkout ›</button>
            <div class="cart-continue" onclick="closeCart()">← Continue shopping</div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        const cart = {};
        function fmt(n) { return '₱' + n.toFixed(2); }

     function getToken() {
    return document.querySelector('input[name="__RequestVerificationToken"]')?.value || '';
}

function addToCart(id, name, cat, price) {
    fetch('/Cart/AddToCart', {
        method: 'POST',
        headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
        body: `productId=${id}&__RequestVerificationToken=${getToken()}`
    });
    if (cart[id]) { cart[id].qty++; }
    else { cart[id] = { name, cat, price, qty: 1 }; }
    renderCart();
    openCart();
}

        function changeQty(id, delta) {
        if (!cart[id]) return;
        cart[id].qty = Math.max(1, cart[id].qty + delta);
        renderCart();
        }

        function removeItem(id) {
        delete cart[id];
        renderCart();
        }

        function openCart() {
        document.getElementById('cartDrawer').classList.add('open');
        document.getElementById('cartOverlay').classList.add('show');
        }

        function closeCart() {
        document.getElementById('cartDrawer').classList.remove('open');
        document.getElementById('cartOverlay').classList.remove('show');
        }

        function renderCart() {
        const keys = Object.keys(cart);
        const container = document.getElementById('drawerItems');
        const footer = document.getElementById('drawerFooter');
        let total = 0, count = 0;

        if (keys.length === 0) {
        container.innerHTML = '<p class="text-muted text-center mt-3">Your cart is empty</p>';
        footer.style.display = 'none';
        document.getElementById('nav-cart-count').textContent = '0';
        document.getElementById('drawer-count').textContent = '0';
        return;
        }

        let html = '';
        keys.forEach(k => {
        const it = cart[k];
        total += it.price * it.qty;
        count += it.qty;
        html += `<div class="cart-item-row">
        <div class="cart-item-thumb">🛍</div>
        <div class="cart-item-info">
        <div class="name">${it.name}</div>
        <div class="cat">${it.cat}</div>
        </div>
        <div class="cart-item-right">
        <div class="price">${fmt(it.price * it.qty)}</div>
        <div class="qty-ctrl">
        <button onclick="changeQty('${k}',-1)">−</button>
        <span>${it.qty}</span>
        <button onclick="changeQty('${k}',1)">+</button>
        </div>
        <span class="cart-remove" onclick="removeItem('${k}')">Remove</span>
        </div>
        </div>`;
        });

        container.innerHTML = html;
        footer.style.display = 'block';
        document.getElementById('d-subtotal').textContent = fmt(total);
        document.getElementById('d-total').textContent = fmt(total);
        document.getElementById('nav-cart-count').textContent = count;
        document.getElementById('drawer-count').textContent = count;
        }
    </script>
</body>
</html>