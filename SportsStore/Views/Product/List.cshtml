@model SportsStore.Models.ViewModels.ProductsListViewModel

<div class="row">

    <!-- Categories Sidebar -->
    <div class="col-lg-3">
        <h4 class="mb-3">Categories</h4>
        <div class="list-group">
            <a asp-controller="Product" asp-action="List"
                   asp-route-productPage="1"
                   class="list-group-item list-group-item-action @(string.IsNullOrEmpty(Model.CurrentCategory) ? "active bg-primary text-white" : "")">
                All Products
            </a>

            @foreach (var cat in ViewBag.Categories as IEnumerable<string> ?? Enumerable.Empty<string>())
            {
                <a asp-controller="Product"
                       asp-action="List"
                       asp-route-category="@cat"
                       asp-route-productPage="1"
                       class="list-group-item list-group-item-action @(Model.CurrentCategory == cat ? "active bg-primary text-white" : "")">
                    @cat
                </a>
            }
        </div>
    </div>

    <!-- Products Area -->
    <div class="col-lg-9">
        <h4 class="mb-4">
            @if (string.IsNullOrEmpty(Model.CurrentCategory))
            {
                <span>All Products</span>
            }
            else
            {
                <span>@Model.CurrentCategory</span>
            }
        </h4>

        @foreach (var p in Model.Products)
        {
            <div class="card mb-3 shadow-sm">
                <div class="card-body d-flex justify-content-between align-items-center">
                    <div>
                        <h5 class="card-title">@p.Name</h5>
                        <p class="card-text text-muted mb-1">@p.Description</p>
                        <small class="text-secondary">@p.Category</small>
                    </div>

                    <div class="text-end">
                        <div class="mb-3">
                            <span class="badge bg-primary fs-5 px-4 py-2">@p.Price.ToString("C")</span>
                        </div>
                        <button class="btn btn-success px-4 py-2"
                                onclick="addToCart('@p.ProductId', '@p.Name', '@p.Category', @p.Price)">
                            Add to Cart
                        </button>
                    </div>
                </div>
            </div>
        }

        <!-- Pagination -->
        @if (Model.PagingInfo.TotalPages > 1)
        {
            <div class="d-flex justify-content-center mt-5">
                <nav aria-label="Product pagination">
                    <ul class="pagination">
                        @for (int i = 1; i <= Model.PagingInfo.TotalPages; i++)
                        {
                            <li class="page-item @(i == Model.PagingInfo.CurrentPage ? "active" : "")">
                                <a class="page-link"
                                       asp-controller="Product"
                                       asp-action="List"
                                       asp-route-productPage="@i"
                                       asp-route-category="@Model.CurrentCategory">
                                    @i
                                </a>
                            </li>
                        }
                    </ul>
                </nav>
            </div>
        }
    </div>
</div>